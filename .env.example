# ═══════════════════════════════════════════════════════════════
# POLYMARKET ULTIMATE BOT - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# TRADING MODE
# Set to "true" for paper trading (simulation, no real money)
# Set to "false" for live trading (REAL MONEY)
# ═══════════════════════════════════════════════════════════════
SIMULATION_MODE=true

# ═══════════════════════════════════════════════════════════════
# POLYMARKET API CREDENTIALS
# Get these from: https://polymarket.com/profile/api
# Required for LIVE trading only
# ═══════════════════════════════════════════════════════════════
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_WALLET=
POLYMARKET_SIGNATURE_TYPE=2

# ═══════════════════════════════════════════════════════════════
# STRATEGY WEIGHTS (must sum to 1.0)
# ═══════════════════════════════════════════════════════════════
SIGNAL_STRATEGY_WEIGHT=0.50
ARBITRAGE_STRATEGY_WEIGHT=0.30
SENTIMENT_STRATEGY_WEIGHT=0.20

# ═══════════════════════════════════════════════════════════════
# SIGNAL STRATEGY SETTINGS
# ═══════════════════════════════════════════════════════════════
ENTRY_BULLISH_THRESHOLD=70
ENTRY_BEARISH_THRESHOLD=30
STRONG_SIGNAL_THRESHOLD=85
EXIT_THRESHOLD=50

# ═══════════════════════════════════════════════════════════════
# ARBITRAGE SETTINGS
# ═══════════════════════════════════════════════════════════════
ARBITRAGE_MIN_SPREAD=0.05
ARBITRAGE_MAX_POSITION=20.0

# ═══════════════════════════════════════════════════════════════
# RISK MANAGEMENT
# ═══════════════════════════════════════════════════════════════
BASE_POSITION_SIZE=10.0
MAX_POSITION_SIZE=50.0
MAX_TOTAL_EXPOSURE=200.0
STRONG_SIGNAL_MULTIPLIER=2.0

STOP_LOSS_PCT=0.15
TAKE_PROFIT_PCT=0.30

MAX_HOLD_TIME_SECONDS=1800
MIN_HOLD_TIME_SECONDS=60

COOLDOWN_AFTER_WIN=300
COOLDOWN_AFTER_LOSS=600

# ═══════════════════════════════════════════════════════════════
# TELEGRAM NOTIFICATIONS (Optional)
# Get bot token from @BotFather
# Get chat ID from @userinfobot
# ═══════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram thresholds
STRONG_BULL_THRESHOLD=78
STRONG_BEAR_THRESHOLD=22
ANTI_SPAM_STRONG_SEC=180
ANTI_SPAM_CHANGE_SEC=300

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_FILE=polymarket_bot.log
DEBUG_MODE=false